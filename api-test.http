@baseUrl = http://localhost:3002
@contentType = application/json

### Root
GET {{baseUrl}}/

### Health check
GET {{baseUrl}}/api/health

### User registration
POST {{baseUrl}}/api/auth/register
Content-Type: {{contentType}}

{
  "fullName": "Arif Yahya",
  "email": "arifyahya@gmail.com",
  "password": "password"
}

### User login
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "admin@example.com",
  "password": "password"
}

### Set Auth Token
@token = {{login.response.body.data.token}}

### Get user profile
GET {{baseUrl}}/api/auth/me
Authorization: Bearer {{token}}
Accept: {{contentType}}

### Logout user
POST {{baseUrl}}/api/auth/logout
Authorization: Bearer {{token}}
Accept: {{contentType}}

### Get all users (admin only)
GET {{baseUrl}}/api/users
Authorization: Bearer {{token}}
Accept: {{contentType}}

### Get user by ID (admin only)
GET {{baseUrl}}/api/users/1
Authorization: Bearer {{token}}
Accept: {{contentType}}

### Create new user (admin only)
POST {{baseUrl}}/api/users
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "fullName": "New User",
  "email": "newuser2@example.com",
  "password": "password",
  "role": "admin"
}

### Update user (admin only)
PATCH {{baseUrl}}/api/users/2
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "fullName": "Updated User",
  "email": "updateduser@example.com"
}

### Delete user (admin only)
DELETE {{baseUrl}}/api/users/2
Authorization: Bearer {{token}}

# ──────────────────────────────────────────────
# ADMIN EVENT ROUTES  (/api/admin/events)
# ──────────────────────────────────────────────

### [Admin] Create event
POST {{baseUrl}}/api/admin/events
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "title": "Tech Conference 2026",
  "description": "A conference about the latest in tech.",
  "capacity": 300,
  "price": 150000,
  "startAt": "2026-09-15 15:00",
  "endAt": "2026-09-15 18:00",
  "location": "New York City"
}

### [Admin] List all events
GET {{baseUrl}}/api/admin/events
Authorization: Bearer {{token}}
Accept: {{contentType}}

### [Admin] Get event by ID
GET {{baseUrl}}/api/admin/events/1
Authorization: Bearer {{token}}
Accept: {{contentType}}

### [Admin] Update event (draft only)
PATCH {{baseUrl}}/api/admin/events/1
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "title": "Updated Tech Conference 2026",
  "capacity": 350
}

### [Admin] Delete event (archived only)
DELETE {{baseUrl}}/api/admin/events/1
Authorization: Bearer {{token}}

### [Admin] Publish event
POST {{baseUrl}}/api/admin/events/1/publish
Authorization: Bearer {{token}}

### [Admin] Cancel event
POST {{baseUrl}}/api/admin/events/1/cancel
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "cancelReason": "Due to unforeseen circumstances, we have to cancel the event."
}

### [Admin] Move cancelled event to draft
POST {{baseUrl}}/api/admin/events/1/move-to-draft
Authorization: Bearer {{token}}

### [Admin] Archive event
POST {{baseUrl}}/api/admin/events/1/archive
Authorization: Bearer {{token}}

# ──────────────────────────────────────────────
# PUBLIC EVENT ROUTES  (/api/events)
# ──────────────────────────────────────────────

### [Public] List published events
GET {{baseUrl}}/api/events
Accept: {{contentType}}

### [Public] Get published event by ID
GET {{baseUrl}}/api/events/3
Accept: {{contentType}}

### [Public] Register for event (auth required)
POST {{baseUrl}}/api/events/3/register
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "quantity": 1
}

# ──────────────────────────────────────────────
# PAYMENT ROUTES
# ──────────────────────────────────────────────

### [Webhook] Midtrans payment notification
POST {{baseUrl}}/api/payments/midtrans/webhook
Content-Type: {{contentType}}

{
  "order_id": "mock-order-id",
  "transaction_status": "settlement",
  "fraud_status": "accept",
  "payment_type": "credit_card",
  "transaction_id": "trx-12345",
  "status_code": "200",
  "gross_amount": "150000",
  "signature_key": "mock-signature"
}
