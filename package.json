{
  "name": "event-management-rest-api",
  "version": "1.0.0",
  "description": "REST API for event management, attendee registration, ticketing, check-in, and reporting.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:all": "concurrently --kill-others -n \"api,worker\" -c \"cyan,magenta\" \"npm run dev\" \"npm run workers\"",
    "build": "tsc -p tsconfig.json && cp -R src/templates/email dist/templates/email",
    "start": "node dist/server.js",
    "worker:create-payment": "tsx watch src/workers/create-payment.worker.ts",
    "worker:order-expire": "tsx watch src/workers/order-expire.worker.ts",
    "worker:send-email": "tsx watch src/workers/send-email.worker.ts",
    "worker:generate-pdf": "tsx watch src/workers/generate-pdf.worker.ts",
    "workers": "tsx watch src/workers/index.ts",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "@supabase/supabase-js": "^2.107.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.61.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "handlebars": "^4.7.9",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.11",
    "nodemailer": "^8.0.10",
    "pdfmake": "^0.3.10",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "rate-limit-redis": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.3",
    "@types/handlebars": "^4.0.40",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.18",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfmake": "^0.3.3",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "concurrently": "^10.0.3",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8",
    "vitest-mock-extended": "^4.0.0"
  }
}
