<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ticket Confirmation - TICKETS.LIVE</title>
  <style>
    body {
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      font-family: 'Hanken Grotesk', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    }
    table {
      border-collapse: collapse;
    }
    a {
      text-decoration: none;
    }
  </style>
</head>
<body style="margin: 0; padding: 0; background-color: #f9f9fb; color: #0b1c30;">
  
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #f9f9fb; padding: 40px 16px;">
    <tr>
      <td align="center">
        
        <!-- Logo Top (Outside White Box) -->
        <table width="100%" cellpadding="0" cellspacing="0" style="max-width: 600px; margin-bottom: 24px; text-align: center;">
          <tr>
            <td align="center">
              <h1 style="margin: 0; color: #1f108e; font-size: 20px; font-weight: 700; display: inline-flex; align-items: center; gap: 8px;">
                <!-- Icon Ticket -->
                <span style="font-size: 24px; vertical-align: middle;">🎟️</span> 
                <span style="vertical-align: middle;">TICKETS.LIVE</span>
              </h1>
            </td>
          </tr>
        </table>

        <!-- Main White Container -->
        <table width="100%" cellpadding="0" cellspacing="0" style="max-width: 600px; background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 0; padding: 40px;">
          <tr>
            <td style="padding: 40px;">
              
              <!-- Success Header -->
              <table width="100%" cellpadding="0" cellspacing="0" style="text-align: center; margin-bottom: 32px;">
                <tr>
                  <td align="center">
                    <div style="display: inline-block; background-color: #e6f7f1; padding: 6px 16px; border-radius: 999px; margin-bottom: 16px;">
                      <span style="color: #2dc68d; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;">
                        ✓ ORDER PAID
                      </span>
                    </div>
                    <h2 style="margin: 0 0 12px 0; font-size: 32px; font-weight: 700; color: #0b1c30; letter-spacing: -0.02em;">
                      Your tickets are ready!
                    </h2>
                    <p style="margin: 0; font-size: 16px; color: #777584;">
                      Order #{{orderNumber}}
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Event Details Hero -->
              <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #f4f5fa; border: 1px solid #dcdce6; border-radius: 8px; margin-bottom: 24px;">
                <tr>
                  <td style="padding: 24px;">
                    <h3 style="margin: 0 0 12px 0; font-size: 22px; font-weight: 600; color: #1f108e;">
                      {{eventTitle}}
                    </h3>
                    <p style="margin: 0 0 8px 0; font-size: 14px; color: #464553;">
                      <span style="vertical-align: middle;">📅</span> <span style="vertical-align: middle; margin-left: 4px;">{{formattedDate}}</span>
                    </p>
                    <p style="margin: 0; font-size: 14px; color: #464553;">
                      <span style="vertical-align: middle;">📍</span> <span style="vertical-align: middle; margin-left: 4px;">{{eventLocation}}</span>
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Order Information Grid -->
              <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #f8f9ff; border: 1px solid #dcdce6; border-radius: 8px; margin-bottom: 40px;">
                <tr>
                  <td style="padding: 24px; width: 50%; vertical-align: top; border-right: 1px solid #e2e8f0;">
                    <p style="margin: 0 0 6px 0; font-size: 11px; font-weight: 600; color: #777584; text-transform: uppercase;">Customer</p>
                    <p style="margin: 0 0 4px 0; font-size: 15px; font-weight: 700; color: #0b1c30;">{{customerName}}</p>
                    <p style="margin: 0; font-size: 14px; color: #464553;">{{to}}</p>
                  </td>
                  <td style="padding: 24px; width: 50%; vertical-align: top;">
                    <p style="margin: 0 0 6px 0; font-size: 11px; font-weight: 600; color: #777584; text-transform: uppercase;">Payment Info</p>
                    <p style="margin: 0 0 4px 0; font-size: 15px; font-weight: 700; color: #0b1c30;">Payment Successful</p>
                    <p style="margin: 0; font-size: 14px; color: #464553;">Quantity: {{quantity}}</p>
                  </td>
                </tr>
              </table>

              <!-- Divider -->
              <hr style="border: 0; border-top: 1px solid #dcdce6; margin: 0 0 24px 0;" />

              <!-- Ticket Codes -->
              {{#if tickets}}
              <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 32px;">
                <tr>
                  <td>
                    <h4 style="margin: 0 0 16px 0; font-size: 18px; font-weight: 600; color: #0b1c30;">Your Tickets</h4>
                    <div style="background-color: #f8f9ff; border: 1px solid #dcdce6; border-radius: 8px; overflow: hidden;">
                      <table width="100%" cellpadding="0" cellspacing="0">
                        {{#each tickets}}
                        <tr>
                          <td style="padding: 12px 16px; border-bottom: 1px solid #e5e7eb; width: 50%;">
                            <span style="font-size: 14px; color: #464553;">Ticket #{{@index_plus_one}}</span>
                          </td>
                          <td style="padding: 12px 16px; border-bottom: 1px solid #e5e7eb; width: 50%; text-align: right;">
                            <span style="font-family: monospace; font-size: 16px; font-weight: 700; color: #1f108e;">{{this.ticketCode}}</span>
                          </td>
                        </tr>
                        {{/each}}
                      </table>
                    </div>
                  </td>
                </tr>
              </table>
              {{/if}}

              <!-- Payment Summary -->
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td style="padding-bottom: 16px;">
                    <h4 style="margin: 0; font-size: 20px; font-weight: 600; color: #0b1c30;">Payment Summary</h4>
                  </td>
                </tr>
                <tr>
                  <td style="padding-bottom: 12px;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="font-size: 14px; color: #464553;">{{quantity}}x Tickets</td>
                        <td style="font-size: 14px; color: #464553; text-align: right;">{{formattedAmount}}</td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="padding-top: 16px; border-top: 1px solid #dcdce6;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td>
                          <span style="font-size: 18px; font-weight: 600; color: #0b1c30;">Total Amount</span>
                        </td>
                        <td style="text-align: right;">
                          <span style="font-size: 18px; font-weight: 700; color: #1f108e;">{{formattedAmount}}</span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Download Button -->
              <table width="100%" cellpadding="0" cellspacing="0" style="margin-top: 40px;">
                <tr>
                  <td align="center">
                    <a href="#" style="display: inline-block; width: 100%; background-color: #1f108e; color: #ffffff; text-align: center; padding: 16px 0; border-radius: 6px; font-size: 16px; font-weight: 600;">
                      <span style="vertical-align: middle;">📥</span> <span style="vertical-align: middle; margin-left: 8px;">Download PDF Tickets</span>
                    </a>
                  </td>
                </tr>
              </table>

            </td>
          </tr>
        </table>

        <!-- Footer -->
        <table width="100%" cellpadding="0" cellspacing="0" style="max-width: 600px; margin-top: 32px; text-align: center;">
          <tr>
            <td align="center" style="padding: 0 24px;">
              <div style="font-size: 12px; font-weight: 700; color: #0b1c30; letter-spacing: 0.05em; margin-bottom: 16px;">TICKETS.LIVE</div>
              <table align="center" cellpadding="0" cellspacing="0" style="margin-bottom: 16px;">
                <tr>
                  <td style="padding: 0 8px;">
                    <a href="#" style="font-size: 14px; color: #006591; text-decoration: underline;">Support</a>
                  </td>
                  <td style="padding: 0 8px;">
                    <a href="#" style="font-size: 14px; color: #006591; text-decoration: underline;">Privacy Policy</a>
                  </td>
                  <td style="padding: 0 8px;">
                    <a href="#" style="font-size: 14px; color: #006591; text-decoration: underline;">Terms of Service</a>
                  </td>
                </tr>
              </table>
              <p style="margin: 0; font-size: 14px; color: #777584;">© 2026 TICKETS.LIVE. All rights reserved.</p>
            </td>
          </tr>
        </table>

      </td>
    </tr>
  </table>

</body>
</html>